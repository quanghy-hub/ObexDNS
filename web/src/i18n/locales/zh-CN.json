  "intro": {
    "item1Title": "Obex 保护性 DNS",
    "item1Desc": "基于 Cloudflare Workers & D1 的 DNS 解析器，尽力提高速度与安全。",
    "item2Title": "DoH 隐私保护",
    "item2Desc": "通过 DNS over HTTPS (RFC 8484) 加密隧道防止劫持并增强隐私。",
    "item3Title": "全球边缘网络",
    "item3Desc": "依托 Cloudflare 庞大的边缘网络，获得极速解析与极低延迟体验。",
    "item4Title": "精细化过滤",
    "item4Desc": "全面支持黑白名单、AdGuard 规则以及自定义 DNS 记录重定向。",
    "item5Title": "实时统计分析",
    "item5Desc": "通过详细的查询日志和综合统计仪表盘，直观展现网络健康状况。",
    "item6Title": "现代 UI 与暗黑模式",
    "item6Desc": "为工程师和家庭用户设计的高密度管理面板，基于由 Palantir 开发的 Blueprint UI。",
    "item7Title": "云原生基础架构",
    "item7Desc": "无服务器架构确保零维护和私人 DNS 的无限扩展性。",
    "item8Title": "多配置管理",
    "item8Desc": "为不同设备或网络环境创建并管理多个独立配置。"
  }
